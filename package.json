{
  "name": "tuicraft",
  "version": "1.0.0",
  "tuiengineVersion": "1.0.0",
  "description": "Starter template for building real-time multiplayer TUI SSH & Web games using Bun and OpenTUI.",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot game/index.ts",
    "create": "bun bin/cli.ts",
    "publish": "bun bin/cli.ts publish",
    "billing-init": "bun bin/cli.ts billing-init",
    "test-boot": "bun run scripts/test-boot.ts",
    "postinstall": "bun run scripts/patch-opentui.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ssh2": "^1.15.5",
    "@types/qrcode": "^1.5.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "^0.4.2",
    "@opentui/ssh": "^0.4.2",
    "qrcode": "^1.5.3",
    "ssh2": "^1.17.0"
  },
  "peerDependencies": {
    "typescript": "^5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "^0.4.2",
    "@opentui/ssh": "^0.4.2",
    "qrcode": "^1.5.3",
    "ssh2": "^1.17.0"
  },
  "dependencies": {
  }
}
